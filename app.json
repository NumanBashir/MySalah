{
  "expo": {
    "name": "MySalah",
    "slug": "MySalah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/MySalahIcon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow MySalah to use your location to calculate prayer times and Qibla direction."
        }
      ],
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "backgroundColor": "#FAF8F3",
      "barStyle": "default",
      "description": "A calm personal prayer time app with Qibla direction.",
      "display": "standalone",
      "favicon": "./assets/favicon.png",
      "lang": "en",
      "name": "MySalah",
      "orientation": "portrait",
      "scope": "/",
      "shortName": "MySalah",
      "splash": {
        "backgroundColor": "#FAF8F3",
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain"
      },
      "startUrl": "/",
      "themeColor": "#557568"
    }
  }
}
